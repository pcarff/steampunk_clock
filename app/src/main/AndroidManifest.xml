<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="net.carff.android.steampunkclock"
    android:versionCode="12"
    android:versionName="2.12">


    <uses-permission android:name="android.permission.INTERNET"/>
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    
    <uses-permission android:name="android.permission.WAKE_LOCK"/>
    
    <uses-feature android:name="android.hardware.touchscreen" android:required="false"/>
    <uses-feature android:name="android.hardware.location.gps" android:required="false"/>
    
    <application 
        android:name=".SteampunkClockApplication"
        android:label="@string/app_name"
        android:icon="@drawable/clock_icon"
        android:theme="@android:style/Theme.DeviceDefault.NoActionBar"
        android:usesCleartextTraffic="true"
        >
        <activity
            android:label="@string/app_name"
            android:name=".ui.HamDashboardActivity"
            android:exported="true"
            android:screenOrientation="fullSensor"
            android:resizeableActivity="true">
            <intent-filter >
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity
            android:name=".ui.WeatherActivity"
            android:label="Weather Station" />
        <activity
            android:name=".ui.GpsAnalysisActivity"
            android:label="GNSS Analysis" />
        <activity
            android:name=".ui.MapActivity"
            android:label="World Map" />
        <activity
            android:name=".ui.SolarActivity"
            android:label="Propagation" />
        <activity
            android:label="@string/app_name"
            android:name=".ui.HomeActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.VIEW"/>
                <category android:name="android.intent.category.DEFAULT"/>
                <category android:name="android.intent.category.BROWSABLE"/>
                <data android:scheme="steampunkclock"/>
            </intent-filter>
        </activity>
        <activity
            android:name=".ui.SettingsActivity"
            android:label="Settings" />
        <service
            android:name=".service.WeatherDataFetchService">
        </service>
        
        <receiver
            android:name=".widget.SteampunkClockTimeWidgetProvider"
            android:label="Steampunk Time Widget"
            android:exported="true">
            <intent-filter>
                <action
                    android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <intent-filter>
                <action
                    android:name="net.carff.android.STEAMPUNKCLOCK_TIME_WIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/time_widget"/>
        </receiver>
        <receiver
            android:name=".widget.SteampunkClockDateWidgetProvider"
            android:label="Steampunk Date Widget"
            android:exported="true">
            <intent-filter>
                <action
                    android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <intent-filter>
                <action
                    android:name="net.carff.android.STEAMPUNKCLOCK_DATE_WIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/date_widget"/>
        </receiver>
    </application>

</manifest>
