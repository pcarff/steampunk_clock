<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:weightSum="3"
    android:padding="4dp">

    <!-- DAY 1 CARD -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:background="@drawable/weather_card_bg"
        android:padding="6dp"
        android:layout_marginEnd="4dp"
        android:gravity="center">
        <TextView
            android:id="@+id/one_day_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SUN"
            android:textColor="#fff0bd"
            android:textSize="10sp"
            android:textStyle="bold" />
        <ImageView
            android:id="@+id/one_day_forecast"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_margin="2dp"
            android:scaleType="fitCenter" />
        <TextView
            android:id="@+id/day_one_temp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="--/--"
            android:textColor="#ffdd00"
            android:textSize="12sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- DAY 2 CARD -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:background="@drawable/weather_card_bg"
        android:padding="6dp"
        android:layout_marginEnd="4dp"
        android:gravity="center">
        <TextView
            android:id="@+id/two_day_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="MON"
            android:textColor="#fff0bd"
            android:textSize="10sp"
            android:textStyle="bold" />
        <ImageView
            android:id="@+id/two_day_forecast"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_margin="2dp"
            android:scaleType="fitCenter" />
        <TextView
            android:id="@+id/day_two_temp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="--/--"
            android:textColor="#ffdd00"
            android:textSize="12sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- DAY 3 CARD -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:background="@drawable/weather_card_bg"
        android:padding="6dp"
        android:gravity="center">
        <TextView
            android:id="@+id/three_day_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="TUE"
            android:textColor="#fff0bd"
            android:textSize="10sp"
            android:textStyle="bold" />
        <ImageView
            android:id="@+id/three_day_forecast"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_margin="2dp"
            android:scaleType="fitCenter" />
        <TextView
            android:id="@+id/day_three_temp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="--/--"
            android:textColor="#ffdd00"
            android:textSize="12sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Hidden Title for compatibility -->
    <TextView android:id="@+id/forecast_title" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
</LinearLayout>
