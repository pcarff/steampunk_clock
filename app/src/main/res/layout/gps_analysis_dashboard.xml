<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="GNSS SIGNAL ANALYSIS"
        android:textColor="#fff0bd"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp" />

    <net.carff.android.steampunkclock.ui.view.SignalTrendView
        android:id="@+id/analysis_signal_trend"
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:layout_marginBottom="16dp" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@drawable/brass_panel_bg"
        android:padding="12dp">
        <TextView
            android:id="@+id/sat_detail_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Scanning satellites..."
            android:textColor="#ffdd00"
            android:textSize="14sp"
            android:fontFamily="monospace" />
    </ScrollView>

    <Button
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="BACK TO DASHBOARD"
        android:onClick="onBackButtonClick"
        android:layout_marginTop="16dp"
        android:backgroundTint="#3d2b1f"
        android:textColor="#fff0bd" />
</LinearLayout>
