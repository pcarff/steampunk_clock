<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/wood_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:gravity="center_horizontal">

        <!-- 1. The Clock (Hub Centerpiece) -->
        <LinearLayout
            android:id="@+id/hub_clock_section"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/brass_panel_bg"
            android:padding="30dp"
            android:layout_marginBottom="24dp"
            android:gravity="center">
            
            <fragment android:name="net.carff.android.steampunkclock.ui.TimeFragment"
                android:id="@+id/hub_time_fragment"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>

        <!-- 2. Interactive Dashboards (2x2 Grid) -->
        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="2"
            android:rowCount="2"
            android:alignmentMode="alignMargins"
            android:columnOrderPreserved="false">

            <!-- WEATHER BUTTON -->
            <LinearLayout
                android:id="@+id/btn_weather"
                android:layout_width="0dp"
                android:layout_height="140dp"
                android:layout_columnWeight="1"
                android:layout_margin="8dp"
                android:background="@drawable/brass_panel_bg"
                android:clickable="true"
                android:focusable="true"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="12dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="WEATHER"
                    android:textColor="#fff0bd"
                    android:textSize="12sp"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/hub_temp_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--°C"
                    android:textColor="#ffdd00"
                    android:textSize="32sp"
                    android:textStyle="bold" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TAP FOR FORECAST"
                    android:textColor="#fff0bd"
                    android:textSize="8sp"
                    android:alpha="0.6" />
            </LinearLayout>

            <!-- GRID LOCATOR BUTTON -->
            <LinearLayout
                android:id="@+id/btn_grid"
                android:layout_width="0dp"
                android:layout_height="140dp"
                android:layout_columnWeight="1"
                android:layout_margin="8dp"
                android:background="@drawable/brass_panel_bg"
                android:clickable="true"
                android:focusable="true"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="12dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="GRID SQUARE"
                    android:textColor="#fff0bd"
                    android:textSize="12sp"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/hub_grid_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="----"
                    android:textColor="#ffdd00"
                    android:textSize="28sp"
                    android:textStyle="bold" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TAP FOR GNSS INFO"
                    android:textColor="#fff0bd"
                    android:textSize="8sp"
                    android:alpha="0.6" />
            </LinearLayout>

            <!-- LOCATION BUTTON -->
            <LinearLayout
                android:id="@+id/btn_location"
                android:layout_width="0dp"
                android:layout_height="140dp"
                android:layout_columnWeight="1"
                android:layout_margin="8dp"
                android:background="@drawable/brass_panel_bg"
                android:clickable="true"
                android:focusable="true"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="12dp">
                <TextView
                    android:id="@+id/hub_city_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="LOCATION"
                    android:textColor="#fff0bd"
                    android:textSize="12sp"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/hub_latlon_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0.0, 0.0"
                    android:textColor="#ffdd00"
                    android:textSize="16sp" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TAP FOR WORLD MAP"
                    android:textColor="#fff0bd"
                    android:textSize="8sp"
                    android:alpha="0.6" />
            </LinearLayout>

            <!-- SOLAR BUTTON -->
            <LinearLayout
                android:id="@+id/btn_solar"
                android:layout_width="0dp"
                android:layout_height="140dp"
                android:layout_columnWeight="1"
                android:layout_margin="8dp"
                android:background="@drawable/brass_panel_bg"
                android:clickable="true"
                android:focusable="true"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="12dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SOLAR FLUX"
                    android:textColor="#fff0bd"
                    android:textSize="12sp"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/hub_solar_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SFI ---"
                    android:textColor="#ffdd00"
                    android:textSize="24sp"
                    android:textStyle="bold" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TAP FOR PROPAGATION"
                    android:textColor="#fff0bd"
                    android:textSize="8sp"
                    android:alpha="0.6" />
            </LinearLayout>
        </GridLayout>

    </LinearLayout>
</ScrollView>
