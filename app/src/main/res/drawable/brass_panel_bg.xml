<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- The outer frame (Dark Brass) -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#3d2b1f" />
            <corners android:radius="8dp" />
        </shape>
    </item>
    
    <!-- The inner gradient (Metallic Brass) -->
    <item android:top="2dp" android:left="2dp" android:right="2dp" android:bottom="2dp">
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#8e6d2d"
                android:centerColor="#d4af37"
                android:endColor="#8e6d2d"
                android:angle="45"
                android:type="linear" />
            <corners android:radius="6dp" />
            <stroke android:width="1dp" android:color="#5e4513" />
        </shape>
    </item>
    
    <!-- The screen area (Dark Recess) -->
    <item android:top="8dp" android:left="8dp" android:right="8dp" android:bottom="8dp">
        <shape android:shape="rectangle">
            <solid android:color="#000000" />
            <corners android:radius="4dp" />
            <stroke android:width="2dp" android:color="#3d2b1f" />
        </shape>
    </item>
</layer-list>
