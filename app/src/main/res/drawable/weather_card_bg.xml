<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Outer Frame -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#5e4513" />
            <corners android:radius="4dp" />
        </shape>
    </item>
    
    <!-- Metallic Inner -->
    <item android:top="1dp" android:left="1dp" android:right="1dp" android:bottom="1dp">
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#d4af37"
                android:endColor="#8e6d2d"
                android:angle="45" />
            <corners android:radius="3dp" />
        </shape>
    </item>
    
    <!-- Recessed Display Area -->
    <item android:top="4dp" android:left="4dp" android:right="4dp" android:bottom="4dp">
        <shape android:shape="rectangle">
            <solid android:color="#1a110a" />
            <corners android:radius="2dp" />
            <stroke android:width="1dp" android:color="#3d2b1f" />
        </shape>
    </item>
</layer-list>
